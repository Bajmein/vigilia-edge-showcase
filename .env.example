# Vigilia Edge — Variables de entorno de ejemplo
# Copiar como .env y completar los valores reales.
# NUNCA subir el .env real al repositorio.

# Notificaciones del sistema
ALERT_EMAIL_FROM=alertas@vigilia-security.tech

# Contacto técnico corporativo
SUPPORT_CONTACT=kenno@vigilia-security.tech

# SMTP (completar con valores reales del entorno)
SMTP_HOST=<SMTP_HOST>
SMTP_PORT=587
# SMTP_USER y SMTP_PASSWORD deben definirse fuera del repositorio (vault, CI secrets)
